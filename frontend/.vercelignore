# Vercel Ignore File
# Files and directories to exclude from Vercel deployment

# Development files
node_modules/
.env.local
.env.development

# Backend files (not needed in frontend deployment)
backend/
*.py
*.pyc
__pycache__/

# Test and docs
tests/
*.test.js
*.spec.js

# IDE and OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Other deployment configs
railway.json
Procfile
