# ========================================
# AI QUEST - Frontend Environment Variables
# ========================================
#
# SECURITY NOTICE:
# - Frontend .env files can only contain PUBLIC information
# - NEVER put API keys, secrets, or credentials here
# - Only use VITE_ prefixed variables
# - These variables are exposed in the browser
#
# ========================================

# API Base URL (Required for Production)
# For local development: Leave commented (uses proxy)
# For production (Vercel): Set to your Railway backend URL
# Example: VITE_API_URL=https://your-app.up.railway.app/api

VITE_API_URL=

# Analytics or Public Keys (Example - not currently used)
# VITE_ANALYTICS_ID=
